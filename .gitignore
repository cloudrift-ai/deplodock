# Python virtual environment
venv/
venv

# Python cache
__pycache__/
*.pyc
*.pyo

# CUDA
*.cubin

# Python egg-info
emmy.egg-info/

# Build and run artifacts
dist/
dump/
build/

# Docker Compose generated files
docker-compose.vllm.yml
nginx.vllm.conf

# PyCharm
.idea

# Local environment / secrets
.env
.env.local
.env.*.local
.env.*
tests/perf/.results/
_test_data

# Experiment outputs
experiments/
# Benchmark run dirs: keep result files (*.txt / *.json) + the run's recipe.yaml snapshot,
# but drop generated logs/state. (Ignore the dir *contents*, not the dir itself, so the
# negations below can re-include specific files.)
recipes/*/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]_*/*
!recipes/*/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]_*/*.txt
!recipes/*/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]_*/*.json
recipes/*/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]_*/recipe.yaml
recipes/**/benchmark*.log
recipes/**/instances.json
recipes/**/tasks.json

# Claude Code per-user local settings (skills/agents under .claude/ are tracked)
.claude/settings.local.json
*-dump/
.claude/scheduled_tasks.lock

# Local-only analysis artifacts (priors / tune DBs / harvest dumps) — never commit
_data/

# Tune-skill work dirs (per-run dump dirs + tee'd logs) — kept in-repo so runs are
# reproducible later, but never committed
_tune/

# For documentation
# Vercel
docs/.vercel

# Node
/docs/node_modules

# Production
/docs/build

# Generated files
/docs/.docusaurus
/docs/.cache-loader

# Misc
/docs/.DS_Store
/docs/.env.local
/docs/.env.development.local
/docs/.env.test.local
/docs/.env.production.local

/docs/npm-debug.log*
/docs/yarn-debug.log*
/docs/yarn-error.log*
